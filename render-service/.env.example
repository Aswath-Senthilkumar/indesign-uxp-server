# Render service environment template. Copy to `.env` and fill in.
# `.env` is gitignored (see .gitignore in this directory). Never commit live values.

# --- supabase (REQUIRED) ---
# Anon key, read-only-scoped. Same values currently used elsewhere in the project.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- service ---
# Port the render service listens on (loopback).
PORT=8765

# Optional bearer token for service auth. Leave UNSET (or empty) to disable.
# When set, every request to the service except /status requires
# `Authorization: Bearer <SERVICE_TOKEN>`. Off by default for local use;
# set this in production behind the Tailscale Funnel.
# SERVICE_TOKEN=

# --- bridge ---
# Bridge HTTP base URL. The render service is a CLIENT of the bridge.
# Default is fine for local: bridge listens on 127.0.0.1:3000.
BRIDGE_URL=http://127.0.0.1:3000

# --- filesystem ---
# Absolute path of the indesign-uxp-server repo root. Anchors `output/`
# (per-render PDF staging). Defaults to the parent of this directory
# (i.e. the repo root when the service is run from `render-service/`).
# Set explicitly if the service runs from a non-default location.
# INDESIGN_REPO_ROOT=

# Where the template manifests (JSON folders) live. These are committed
# to the repo, organized by workflow:
#   ${TEMPLATE_MANIFEST_DIR}/<workflow>/<TemplateName>/manifest.json
# Default is the in-repo `template-manifests/` directory. Don't override
# unless you're running the service against a non-default checkout.
# TEMPLATE_MANIFEST_DIR=

# Where the .indd template files live. NOT in the repo — .indd files
# are large (~200 MB) and exceed GitHub's per-file limit. Default is a
# sibling directory of the repo (`<repo>/../indesign-templates/`).
# Operator drops the .indd files referenced by manifests into this
# directory. The service errors loud at boot if it doesn't exist or
# contains no .indd files.
# TEMPLATES_DIR=
